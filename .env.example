# Copia questo file come `.env` nella radice del progetto (accanto a package.json).
# I valori li trovi in Supabase: Dashboard → Project Settings → API.

# URL del progetto (es. https://xxxxxxxx.supabase.co) — obbligatorio anche in locale e su Vercel
# Nessuno spazio prima del valore (scrivere VITE_SUPABASE_URL=https://... e non "= https://...")
VITE_SUPABASE_URL=

# Chiave anon / public (sicura da esporre nel browser; RLS protegge i dati)
VITE_SUPABASE_ANON_KEY=
